{
    "name": "TowerDefense",
    "emitLegacyScripts": false,
    "tree": {
        "$className": "DataModel",

        "ReplicatedStorage": {
            "$ignoreUnknownInstances": true,
            "Shared": { "$path": "src/Shared" },
            "Packages": { "$path": "Packages" }
        },
        "ServerScriptService": {
            "$ignoreUnknownInstances": true,
            "$path": "src/Server"
        },
        "ServerStorage": {
            "$ignoreUnknownInstances": true,
            "DevPackages": { "$path": "DevPackages" }
        },
        "StarterPlayer": {
            "$ignoreUnknownInstances": true,
            "StarterPlayerScripts": {
                "$ignoreUnknownInstances": true,
                "$path": "src/Client"
            }
        }
    }
}
